{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "moduleResolution": "Node",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "noEmit": true,
        "types": [
            "@types/service-worker-mock"
        ]
    },
    "include": [
        "src/**/*",
        "public/**/*"
    ]
}