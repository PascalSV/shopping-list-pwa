# Environment variables for development (local)
# Copy to .dev.vars for local development
# Do not commit to version control

# Local development secret for Pascal token
shopping-list-pwa-token-pascal=test-password-local

# Local development secret for Claudia token
shopping-list-pwa-token-claudia=test-token-claudia

# Sync secret (set to actual value if needed)
SYNC_SECRET=set-me-in-dashboard
